---
import Layout from "@/layouts/Layout.astro";

import AboutMe from "@/components/AboutMe.astro";
import CodeIcon from "@/components/icons/Code.astro";
import ProfileCheck from "@/components/icons/ProfileCheck.astro";
import Projects from "@/components/Projects.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import Hero from "@/components/Hero.astro";
import TitleSection from "@/components/TitleSection.astro";
import Certifications from "@/components/Certifications.astro";
---

<Layout
  title="Brian Leonardo Martínez Cobos — Desarrollador Full Stack"
  description="Portafolio de Brian Leonardo Martínez Cobos, Desarrollador Full Stack especializado en Next.js, React, TypeScript, Node.js, Express, NestJS, PostgreSQL y React Native. Construyo productos digitales escalables con enfoque en tiempo real, UX y arquitectura limpia."
  type="profile"
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-36">
      <Hero />
    </SectionContainer>
  </main>

  <div class="space-y-24 md:space-y-32">
    <SectionContainer id="proyectos">
      <TitleSection>
        <CodeIcon class="size-7" />
        Proyectos
      </TitleSection>
      <Projects />
    </SectionContainer>

    <SectionContainer id="certificaciones">
      <Certifications />
    </SectionContainer>

    <SectionContainer id="sobre-mi">
      <TitleSection>
        <ProfileCheck class="size-8" />
        Sobre mí
      </TitleSection>
      <AboutMe />
    </SectionContainer>
  </div>
</Layout>