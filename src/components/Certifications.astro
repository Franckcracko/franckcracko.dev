---
interface Certification {
  title: string;
  image: string;
  date: string;
  issuer: string;
}

const CERTIFICATIONS: Certification[] = [
  {
    title: "Google AI Essentials",
    image: "/certifications/ai-essentials.webp",
    date: "2026-06",
    issuer: "Google · Coursera",
  },
];
---

<section id="certificaciones" class="scroll-m-20 w-full mx-auto container lg:max-w-4xl md:max-w-2xl px-4">
  <h2 class="flex items-center mb-12 text-3xl font-semibold gap-x-3 text-black/80 dark:text-white">
    <svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
    </svg>
    Certificaciones
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="certifications-grid">
    {CERTIFICATIONS.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).map((cert, index) => (
      <article
        class="certification-card group relative flex flex-col overflow-hidden rounded-2xl bg-white dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700/50 shadow-sm hover:shadow-xl transition-all duration-500 ease-out hover:-translate-y-1"
        data-index={index}
        style={`--delay: ${index * 100}ms`}
      >
        <div class="relative aspect-[3/2] overflow-hidden">
          <img
            src={cert.image}
            alt={`Certificado de ${cert.title}`}
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
          <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
            <p class="text-sm text-white/90">{cert.issuer}</p>
          </div>
        </div>
        <div class="p-4">
          <h3 class="font-semibold text-gray-800 dark:text-gray-100 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors line-clamp-2">
            {cert.title}
          </h3>
          <time class="mt-2 block text-xs text-gray-500 dark:text-gray-400" datetime={cert.date}>
            {new Date(cert.date).toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}
          </time>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .certification-card {
    opacity: 0;
    transform: translateY(30px);
    animation: reveal 0.6s ease-out forwards;
    animation-delay: var(--delay);
  }

  @keyframes reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .certification-card {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.certification-card').forEach((card) => {
    observer.observe(card);
  });
</script>