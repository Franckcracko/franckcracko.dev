---
const personalImageAlt = "Brian Leonardo"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
import DownloadIcon from "@/components/icons/DownloadIcon.astro"
---

<div class="relative overflow-hidden">
  <div class="absolute -top-20 -right-20 w-72 h-72 bg-gradient-to-br from-blue-500/20 via-purple-500/10 to-transparent rounded-full blur-3xl -z-10"></div>
  <div class="absolute -bottom-10 -left-10 w-48 h-48 bg-gradient-to-tr from-emerald-500/20 via-cyan-500/10 to-transparent rounded-full blur-3xl -z-10"></div>

  <div class="max-w-2xl">
    <div class="flex flex-col sm:flex-row gap-4 mb-6">
      <img
        class="rounded-full shadow-xl size-20 ring-4 ring-white dark:ring-gray-800"
        src="/franckcracko.webp"
        alt={personalImageAlt}
      />
      <div class="flex flex-col justify-center">
        <a
          href="https://linkedin.com/in/franckcracko"
          target="_blank"
          rel="noopener"
          class="inline-flex w-fit"
        >
          <Badge>Disponible para trabajar</Badge>
        </a>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
          Ingeniería en Tecnologías de la Información
        </p>
      </div>
    </div>

    <h1
      class="text-4xl md:text-5xl font-bold tracking-tight text-gray-900 dark:text-white"
    >
      <span class="block">Construyo experiencias</span>
      <span class="block text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 dark:from-blue-400 dark:to-purple-400">
        que conectan
      </span>
    </h1>

    <p class="mt-6 text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
      Desarrollador Full Stack con pasión por crear interfaces que las personas
      <span class="font-medium text-gray-800 dark:text-gray-200"> aman usar</span>.
      Combino código limpio con diseño intuitivo para transformar ideas en
      productos digitales que generan impacto real.
    </p>

    <div class="mt-8">
      <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-3">
        Stack tecnológico
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          Next.js
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="2"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93z"/></svg>
          React
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          TypeScript
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
          Node.js
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><ellipse cx="12" cy="12" rx="10" ry="6"/></svg>
          PostgreSQL
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          Tailwind
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          Prisma
        </span>
        <span class="tech-badge group">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a2 2 0 01-2-2v-6a2 2 0 012-2h2v4l4-4z"/></svg>
          React Native
        </span>
      </div>
    </div>

    <div class="mt-10 flex flex-col sm:flex-row gap-4">
      <a
        href="mailto:brianleonardomtzcoboswigueta@gmail.com"
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-semibold transition-all hover:scale-105 hover:shadow-lg hover:shadow-gray-900/25 dark:hover:shadow-white/25 focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2"
      >
        <MailIcon class="size-5" />
        Envíame un mensaje
      </a>

      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-200 font-semibold transition-all hover:border-blue-500 hover:text-blue-600 dark:hover:border-blue-400 dark:hover:text-blue-400 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
      >
        <DownloadIcon class="size-5" />
        Descargar CV
      </a>

      <SocialPill href="https://linkedin.com/in/franckcracko">
        <LinkedInIcon class="size-4" />
        LinkedIn
      </SocialPill>
    </div>
  </div>
</div>

<style>
  .tech-badge {
    @apply inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium
           bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300
           border border-gray-200 dark:border-gray-700
           transition-all duration-200 hover:border-blue-400 hover:text-blue-600 dark:hover:border-blue-400
           hover:scale-105;
  }

  .tech-badge svg {
    @apply text-blue-500 dark:text-blue-400;
  }
</style>